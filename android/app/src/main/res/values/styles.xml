<resources xmlns:tools="http://schemas.android.com/tools">
  <style name="ExpoCropPopupMenuItemText" parent="@android:style/TextAppearance.Material.Widget.PopupMenu.Large">
    <item name="android:textColor">#0B1F33</item>
  </style>
  <style name="ExpoCropPopupMenuStyle" parent="Widget.AppCompat.PopupMenu">
    <item name="android:popupBackground">#FFFFFF</item>
    <item name="android:itemTextAppearance">@style/ExpoCropPopupMenuItemText</item>
  </style>
  <style name="ExpoCropPanelMenuListTheme" parent="Theme.AppCompat.Light">
    <item name="android:textColorPrimary">#0B1F33</item>
    <item name="android:textColorSecondary">#0B1F33</item>
    <item name="android:colorBackground">#FFFFFF</item>
  </style>
  <style name="ExpoCropImageThemeOverride" parent="Base.Theme.AppCompat">
    <item name="android:popupMenuStyle">@style/ExpoCropPopupMenuStyle</item>
    <item name="popupMenuStyle">@style/ExpoCropPopupMenuStyle</item>
    <item name="android:actionOverflowMenuStyle">@style/ExpoCropPopupMenuStyle</item>
    <item name="actionOverflowMenuStyle">@style/ExpoCropPopupMenuStyle</item>
    <item name="android:textColorPrimary">#0B1F33</item>
  </style>
  <style name="AppTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
    <item name="android:editTextBackground">@drawable/rn_edit_text_material</item>
    <item name="colorPrimary">@color/colorPrimary</item>
    <item name="android:statusBarColor">@android:color/transparent</item>
    <item name="android:navigationBarColor">@android:color/transparent</item>
  </style>
  <style name="Theme.App.SplashScreen" parent="AppTheme">
    <item name="android:windowBackground">@drawable/ic_launcher_background</item>
  </style>
</resources>