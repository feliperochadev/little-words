{
  "expo": {
    "name": "Little Words",
    "slug": "little-words",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon_1024.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "backgroundColor": "#FAF4EC",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.littlewords.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon_1024.png",
        "backgroundColor": "#FAF4EC"
      },
      "package": "com.littlewords.app",
      "permissions": [
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "expo-file-system",
        {
          "appleUsageDescription": "Usado para exportar CSV"
        }
      ],
      "expo-asset"
    ],
    "scheme": "little-words",
    "extra": {
      "eas": {
        "projectId": "8b714eaf-faf2-4a5c-8716-051982971422"
      }
    }
  }
}
