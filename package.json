    "@babel/core": "^7.24.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.10",
    "eslint": "^9.39.4",
    "eslint-config-expo": "^55.0.0",
