{
  "name": "little-words",
  "version": "0.10.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "build:android": "eas build --platform android --profile prevießw",
    "build:apk": "eas build --platform android --profile apk",
    "build:apk-local": "expo prebuild --clean --platform android && cd android && ./gradlew assembleRelease",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "ci": "npm run lint && npm run typecheck && npm run test:coverage && npm run semgrep",
    "semgrep": "semgrep --config p/default --error .",
    "agent:review": "npx tsx scripts/agent/review-loop.ts",
    "agent:check-tasks": "npx tsx scripts/agent/task-persistence.ts",
    "agent:availability": "npx tsx scripts/agent/agent-availability.ts",
    "e2e": "maestro test __tests__/e2e/full-e2e.yaml",
    "e2e:onboarding": "maestro test __tests__/e2e/onboarding.yaml",
    "e2e:crud-word": "maestro test __tests__/e2e/crud-word.yaml",
    "e2e:crud-variant": "maestro test __tests__/e2e/crud-variant.yaml",
    "e2e:crud-category": "maestro test __tests__/e2e/crud-category.yaml",
    "e2e:import": "maestro test __tests__/e2e/import-words.yaml",
    "e2e:export": "maestro test __tests__/e2e/export-words.yaml",
    "e2e:delete-all-data": "maestro test __tests__/e2e/delete-all-data.yaml",
    "e2e:re-onboard": "maestro test __tests__/e2e/re-onboard.yaml",
    "e2e:demo": "maestro test __tests__/e2e/demo-flow.yaml",
    "e2e:demo-br": "maestro test __tests__/e2e/demo-br-flow.yaml",
    "prepare": "husky"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@tanstack/react-query": "^5.97.0",
    "axios": "^1.15.0",
    "date-fns": "^4.1.0",
    "expo": "~55.0.15",
    "expo-asset": "~55.0.10",
    "expo-audio": "~55.0.13",
    "expo-constants": "~55.0.9",
    "expo-dev-client": "~55.0.27",
    "expo-document-picker": "~55.0.13",
    "expo-file-system": "~55.0.11",
    "expo-font": "^55.0.4",
    "expo-image-picker": "~55.0.18",
    "expo-linking": "~55.0.13",
    "expo-media-library": "~55.0.14",
    "expo-notifications": "~55.0.19",
    "expo-router": "~55.0.12",
    "expo-sharing": "~55.0.18",
    "expo-sqlite": "~55.0.15",
    "expo-status-bar": "~55.0.5",
    "expo-system-ui": "~55.0.15",
    "fflate": "^0.8.2",
    "react": "19.2.0",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-keyboard-controller": "1.20.7",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-view-shot": "4.0.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.10",
    "eslint": "^9.39.4",
    "eslint-config-expo": "^55.0.0",
    "husky": "^9.1.7",
    "jest": "30.3.0",
    "jest-expo": "~55.0.16",
    "react-test-renderer": "19.2.0",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "http-proxy-agent": "^7.0.2",
    "jest-circus": "30.1.0",
    "jest-runner": "30.1.0",
    "jest-runtime": "30.1.0",
    "jest-snapshot": "30.1.0",
    "expect": "30.1.0",
    "@jest/core": "30.1.0",
    "@jest/console": "30.1.0",
    "@jest/fake-timers": "30.1.0",
    "@jest/transform": "30.1.0",
    "@jest/reporters": "30.1.0",
    "@jest/test-sequencer": "30.1.0",
    "@jest/test-result": "30.1.0",
    "jest-environment-node": "30.1.0",
    "jest-resolve": "30.1.0",
    "jest-environment-jsdom": "30.1.0",
    "jest-watch-typeahead": "3.0.1",
    "jsdom": "28.1.0",
    "react-dom": "19.2.0",
    "undici": "^7.24.0"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "listUnknownPackages": false
      }
    },
    "install": {
      "exclude": [
        "jest",
        "@types/jest"
      ]
    }
  },
  "private": true
}
